{
  "name": "@warah/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "test": "jest --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^2.1.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/throttler": "^6.2.0",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.47.0",
    "@supabase/supabase-js": "^2.47.0",
    "@types/nodemailer": "^8.0.1",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "mrz": "^5.0.2",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^9.0.3",
    "p-retry": "^6.2.0",
    "pdfkit": "^0.15.0",
    "pino-http": "^10.3.0",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.1.0",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.0",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "@types/web-push": "^3.6.3",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!mrz/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
