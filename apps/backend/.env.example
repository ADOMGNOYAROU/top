# ═══════════════════════════════════════════════════════════════
# WARAH — Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS commiter le fichier .env
# Voir docs/ENV.md pour les instructions complètes.
# ═══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
NODE_ENV=development
# Port d'écoute (Railway injecte automatiquement $PORT en prod)
PORT=3000

# ── Base de données — Supabase PostgreSQL ─────────────────────
# Transaction pooler (port 6543) — utilisé par l'application en production (pgBouncer)
# Format : postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Connexion directe (port 5432) — utilisée par prisma migrate deploy (ne pas utiliser pgBouncer ici)
DIRECT_URL=postgresql://postgres.VOTRE_PROJECT_REF:VOTRE_MOT_DE_PASSE@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── Supabase ──────────────────────────────────────────────────
# Disponible dans : Settings → API
SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.VOTRE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.VOTRE_SERVICE_ROLE_KEY
# Optionnel — SupabaseAuthGuard valide les JWT via l'API Admin Supabase
# (auth.getUser()), pas besoin du secret pour une vérification locale HS256
SUPABASE_JWT_SECRET=

# ── Resend — Emails transactionnels ───────────────────────────
# Créer une clé API sur resend.com → API Keys
RESEND_API_KEY=re_VOTRE_CLE_API
# Adresse expéditrice vérifiée dans Resend (domaine vérifié requis)
RESEND_FROM_EMAIL=noreply@warah.tg
RESEND_FROM_NAME=WARAH

# ── Web Push — Notifications push VAPID ──────────────────────
# Générer les clés : npx web-push generate-vapid-keys
# (voir docs/ENV.md pour la procédure complète)
VAPID_PUBLIC_KEY=BI0VOTRE_CLE_PUBLIQUE_VAPID
VAPID_PRIVATE_KEY=VOTRE_CLE_PRIVEE_VAPID
# Contact pour les serveurs push (mailto ou URL)
VAPID_SUBJECT=mailto:contact@warah.tg

# ── Cashpay / Semoa — Mobile money (T-Money & Flooz) ─────────
# COMPTE MARCHAND REQUIS — voir docs/DEPLOYMENT.md pour la procédure
# URL de l'API Cashpay fournie par Semoa
CASHPAY_API_URL=https://api.cashpay.tg/v1
CASHPAY_API_KEY=VOTRE_CLE_API_CASHPAY
# Secret HMAC pour valider les webhooks entrants
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CASHPAY_WEBHOOK_SECRET=VOTRE_SECRET_HMAC_CASHPAY

# ── Sentry — Monitoring d'erreurs (optionnel en dev) ─────────
# COMPTE SENTRY REQUIS — voir docs/DEPLOYMENT.md
# Laisser vide en dev local pour désactiver Sentry
SENTRY_DSN=

# ── CORS ──────────────────────────────────────────────────────
# Liste des origines autorisées, séparées par des virgules
# En prod : URL Vercel + éventuellement domaine custom
ALLOWED_ORIGINS=http://localhost:4200,https://warah.vercel.app
